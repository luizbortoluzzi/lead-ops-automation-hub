# ---------------------------------------------------------------------------
# LeadOps Automation Hub — local example values ONLY.
# Copy this file to `.env` and adjust as needed. Never commit a real `.env`.
# ---------------------------------------------------------------------------

NODE_ENV=development

# PostgreSQL (container)
POSTGRES_DB=leadops
POSTGRES_USER=leadops
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Backend API
BACKEND_PORT=3000

# Frontend (React SPA served by nginx, reverse-proxies /api to the backend)
FRONTEND_PORT=5173

# How the backend connects to Postgres (host is the compose service name).
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=leadops
DATABASE_USER=leadops
DATABASE_PASSWORD=change-me

# Machine-to-machine auth between n8n and the backend (X-API-Key).
BACKEND_API_KEY=change-me-development-key

# n8n
N8N_PORT=5678
TZ=America/Sao_Paulo

# Mailpit (local e-mail capture)
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=leadops@example.local
SALES_NOTIFICATION_EMAIL=sales@example.local
