# ---------------------------------------------------------------------------
# LeadOps Automation Hub — local example values ONLY.
# Copy this file to `.env` and adjust as needed. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_DB=leadops
POSTGRES_USER=leadops
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Backend API
BACKEND_PORT=3000
# Host used inside the compose network is the postgres service name.
DATABASE_URL=postgresql://leadops:change-me@postgres:5432/leadops

# n8n
N8N_PORT=5678

# Shared
TZ=America/Sao_Paulo
